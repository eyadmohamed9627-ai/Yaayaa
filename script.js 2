function renderProducts() {
    const grid = document.getElementById('productsGrid');
    
    // بيمسح اللي موجود ويحط الجديد بناءً على المصفوفة اللي فوق
    grid.innerHTML = products.map(product => `
        <div class="product-card">
            <div class="product-image">
                <img src="${product.image}" alt="${product.name}" onerror="this.src='https://via.placeholder.com/300?text=Image+Coming+Soon'">
            </div>
            <div class="product-info">
                <h3 class="product-title">${product.name}</h3>
                <div class="product-price">${product.price} ج.م</div>
                <button class="add-to-cart" onclick="addToCart(${product.id})">
                    <i class="fas fa-shopping-cart"></i> أضيفي للشنطة
                </button>
            </div>
        </div>
    `).join('');
}

// تشغيل الدالة أول ما الصفحة تفتح
renderProducts();
